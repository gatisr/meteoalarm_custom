{
  "name": "meteoalarm-card",
  "version": "1.0.0",
  "private": true,
  "description": "Lovelace card for the MeteoAlarm Custom integration",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && esbuild src/meteoalarm-card.ts --bundle --minify --format=esm --outfile=../custom_components/meteoalarm_custom/frontend/meteoalarm-card.js",
    "watch": "esbuild src/meteoalarm-card.ts --bundle --format=esm --outfile=../custom_components/meteoalarm_custom/frontend/meteoalarm-card.js --watch"
  },
  "dependencies": {
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "typescript": "^7.0.2"
  }
}
